#!/bin/sh

interface="$(uci -q get mcu.global.vpn_interface)"
vpn_zone="$(uci -q get mcu.global.vpn_zone)"
lan_subnet="$(uci -q get mcu.global.vpn_lan_subnet)"
lan_device="$(uci -q get mcu.global.vpn_lan_device)"
route_table="$(uci -q get mcu.global.vpn_route_table)"
rule_priority="$(uci -q get mcu.global.vpn_rule_priority)"
list_dir=/etc/split-routes
batch_file=/tmp/vpn-switch.routes
state_file=/tmp/vpn-switch.state
switch_file=/tmp/vpn-switch.switch

[ -n "$interface" ] || interface=awg0
[ -n "$vpn_zone" ] || vpn_zone=vpn
[ -n "$lan_subnet" ] || lan_subnet=192.168.201.0/24
[ -n "$lan_device" ] || lan_device=br-lan
[ -n "$route_table" ] || route_table=100
[ -n "$rule_priority" ] || rule_priority=10000

log_error() {
	logger -t vpn-switch -p user.err "$*"
	echo "vpn-switch: $*" >&2
}

validate_main_route() {
	if ip -4 route show table main default |
		grep -qE "(^|[[:space:]])dev[[:space:]]+$interface([[:space:]]|$)"; then
		log_error \
			"main default uses $interface; disable Route Allowed IPs for its default peer route"
		return 1
	fi
}

interface_is_up() {
	ubus call "network.interface.$interface" status 2>/dev/null |
		jsonfilter -q -e '@.up' | grep -qx true
}

ensure_firewall() {
	local vpn_zone_section

	vpn_zone_section="$(
		uci -q show firewall |
			sed -n "s/^firewall\\.\\([^.=]*\\)\\.name='$vpn_zone'$/\\1/p" |
			head -n 1
	)"

	if [ -z "$vpn_zone_section" ]; then
		vpn_zone_section="$vpn_zone"
		uci set "firewall.$vpn_zone_section=zone"
	fi

	uci set "firewall.$vpn_zone_section.name=$vpn_zone"
	uci set "firewall.$vpn_zone_section.input=REJECT"
	uci set "firewall.$vpn_zone_section.output=ACCEPT"
	uci set "firewall.$vpn_zone_section.forward=REJECT"
	uci set "firewall.$vpn_zone_section.network=$interface"
	uci set "firewall.$vpn_zone_section.masq=1"
	uci set "firewall.$vpn_zone_section.mtu_fix=1"

	uci -q get firewall.lan_wan >/dev/null ||
		uci set firewall.lan_wan=forwarding
	uci set firewall.lan_wan.src=lan
	uci set firewall.lan_wan.dest=wan
	uci -q delete firewall.lan_wan.enabled

	uci -q get firewall.lan_vpn >/dev/null ||
		uci set firewall.lan_vpn=forwarding
	uci set firewall.lan_vpn.src=lan
	uci set firewall.lan_vpn.dest="$vpn_zone"
	uci -q delete firewall.lan_vpn.enabled

	uci commit firewall
	service firewall reload
}

ensure_rule() {
	while ip -4 rule del priority "$rule_priority" 2>/dev/null; do :; done
	ip -4 rule add priority "$rule_priority" \
		iif "$lan_device" from "$lan_subnet" lookup "$route_table"
}

remove_policy() {
	while ip -4 rule del priority "$rule_priority" 2>/dev/null; do :; done
	ip -4 route flush table "$route_table" 2>/dev/null || true
}

load_lists() {
	: >"$batch_file"

	for list in "$list_dir"/*.lst; do
		[ -f "$list" ] || continue
		awk -v dev="$interface" -v table="$route_table" '
			/^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
			$1 ~ /^[0-9.]+\/[0-9]+$/ {
				print "route replace " $1 " dev " dev " table " table
			}
		' "$list" >>"$batch_file"
	done

	ip -4 route flush table "$route_table"
	ip -4 -batch "$batch_file" || {
		log_error "failed to load routes from $list_dir"
		return 1
	}

	ensure_rule || {
		log_error "failed to install rule for $lan_subnet"
		return 1
	}

	logger -t vpn-switch \
		"loaded $(wc -l <"$batch_file") routes into table $route_table"
}

apply_mode() {
	local switch_state
	local mode

	ensure_firewall || return 1
	switch_state="$(cat "$switch_file" 2>/dev/null || echo off)"

	if ! interface_is_up; then
		remove_policy
		mode=wan
	elif [ "$switch_state" = "on" ]; then
		validate_main_route || return 1
		load_lists || return 1
		ip -4 route replace default dev "$interface" table "$route_table"
		mode=full
	else
		validate_main_route || return 1
		load_lists || return 1
		mode=split
	fi

	echo "$mode" >"$state_file"
	logger -t vpn-switch \
		"mode=$mode switch=$switch_state interface=$interface lan=$lan_subnet iif=$lan_device table=$route_table"
}

set_switch() {
	echo "$1" >"$switch_file"
	apply_mode
}

show_status() {
	echo "mode: $(cat "$state_file" 2>/dev/null || echo unknown)"
	echo "switch: $(cat "$switch_file" 2>/dev/null || echo off)"
	echo "interface: $interface"
	echo "LAN rule:"
	ip -4 rule show | grep "^$rule_priority:" || true
	echo "VPN table:"
	ip -4 route show table "$route_table"
	echo "main default:"
	ip -4 route show table main default
}

case "$1" in
	init)
		[ -f "$switch_file" ] || echo off >"$switch_file"
		apply_mode
		;;
	reload|sync)
		apply_mode
		;;
	on|off)
		set_switch "$1"
		;;
	wan)
		remove_policy
		echo wan >"$state_file"
		logger -t vpn-switch "mode=wan interface=$interface"
		;;
	status)
		show_status
		;;
	*)
		echo "usage: vpn-switch init|reload|sync|on|off|wan|status" >&2
		exit 2
		;;
esac
