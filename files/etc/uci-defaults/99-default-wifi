#!/bin/sh

set -eu

set_radio_ap() {
	local dev="$1"
	local ssid="$2"
	local ifname

	ifname="$(uci -q show wireless | sed -n "s/^wireless\\.\\([^.=]*\\)=wifi-iface$/\\1/p" | while read -r section; do
		[ "$(uci -q get wireless.${section}.device)" = "${dev}" ] || continue
		echo "${section}"
		break
	done)"

	if [ -z "${ifname}" ]; then
		ifname="$(uci add wireless wifi-iface)"
	fi

	uci set "wireless.${dev}.disabled=0"
	uci set "wireless.${ifname}.device=${dev}"
	uci set "wireless.${ifname}.mode=ap"
	uci set "wireless.${ifname}.network=lan"
	uci set "wireless.${ifname}.ssid=${ssid}"
	uci set "wireless.${ifname}.encryption=psk2"
	uci set "wireless.${ifname}.key=12345678"
	uci delete "wireless.${ifname}.disabled" 2>/dev/null || true
}

for dev in $(uci -q show wireless | sed -n 's/^wireless\.\([^.=]*\)=wifi-device$/\1/p'); do
	band="$(uci -q get wireless.${dev}.band || true)"
	case "${band}" in
		2g)
			set_radio_ap "${dev}" "openwrt"
			;;
		5g)
			set_radio_ap "${dev}" "openwrt_5g"
			;;
	esac
done

uci commit wireless
wifi reload || true

exit 0
