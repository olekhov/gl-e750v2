#!/bin/sh /etc/rc.common

START=98
STOP=9
USE_PROCD=1

start_service() {
	# MCU owns ttyS0, so keep kernel console messages off this UART.
	echo 1 4 1 7 > /proc/sys/kernel/printk

	procd_open_instance
	procd_set_param command /usr/bin/eco /usr/bin/mcu
	procd_set_param env LUA_CPATH=";;/usr/lib/lua/?.so"
	procd_set_param respawn 3600 10 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	# Notifications are sent by mcu_shutdown or the explicit sysupgrade hook.
	# A regular service restart must not display "rebooting".
	echo 7 4 1 7 > /proc/sys/kernel/printk
}
