#!/bin/sh /etc/rc.common

START=98
STOP=8
USE_PROCD=1

start_service() {
	# MCU owns ttyS0, so keep kernel console messages off this UART.
	echo 1 4 1 7 > /proc/sys/kernel/printk

	procd_open_instance
	procd_set_param command /usr/bin/eco /usr/bin/mcu
	procd_set_param env LUA_CPATH=";;/usr/lib/lua/?.so"
	procd_set_param respawn 3600 10 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	if ps | grep -q '[s]ysupgrade'; then
		ubus call mcu system_update 2>/dev/null
	else
		ubus call mcu system_reboot 2>/dev/null
	fi
	sleep 1
}
