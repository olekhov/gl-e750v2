config statistics 'collectd'
	option BaseDir '/var/run/collectd'
	option PIDFile '/var/run/collectd.pid'
	option PluginDir '/usr/lib/collectd'
	option TypesDB '/usr/share/collectd/types.db'
	option Interval '30'
	option ReadThreads '2'

config statistics 'rrdtool'
	option default_timespan '21600'
	option image_width '600'
	option image_height '150'

config statistics 'collectd_rrdtool'
	option enable '1'
	option DataDir '/tmp/rrd'
	option RRARows '720'
	option RRASingle '1'
	option CacheTimeout '120'
	option CacheFlush '900'
	list RRATimespans '3600'
	list RRATimespans '21600'
	list RRATimespans '86400'
	list RRATimespans '604800'

config statistics 'collectd_cpu'
	option enable '1'
	option ReportByCpu '1'
	option ReportByState '1'
	option ValuesPercentage '1'

config statistics 'collectd_load'
	option enable '1'

config statistics 'collectd_memory'
	option enable '1'
	option ValuesAbsolute '1'
	option ValuesPercentage '0'

config statistics 'collectd_interface'
	option enable '1'
	option IgnoreSelected '0'
	list Interfaces 'br-lan'
	list Interfaces 'wwan0'
	list Interfaces 'awg0'

config statistics 'collectd_iwinfo'
	option enable '1'

config statistics 'collectd_exec'
	option enable '1'

config collectd_exec_input
	option cmdline '/usr/libexec/collectd/mcu'
	option cmduser 'nobody'
	option cmdgroup 'nogroup'
