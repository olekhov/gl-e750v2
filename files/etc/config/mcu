config global 'global'
	option main_enabled '1'
	option wifi_2g_enabled '1'
	option wifi_5g_enabled '1'
	option lan_enabled '1'
	option vpn_enabled '1'
	option vpn_interface 'awg0'
	option vpn_zone 'vpn'
	option vpn_lan_subnet '192.168.201.0/24'
	option vpn_lan_device 'br-lan'
	option vpn_route_table '100'
	option vpn_rule_priority '10000'
	option custom_enabled '0'
	option content ''
	option wifi_password_enabled '1'
	option power_saveing '0'
